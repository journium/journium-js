{
  "name": "@journium/angular",
  "version": "2.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Journium Angular integration - Service, module, and providers for Angular applications",
  "module": "dist/fesm2022/journium-angular.mjs",
  "types": "dist/types/journium-angular.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/journium-angular.d.ts",
      "default": "./dist/fesm2022/journium-angular.mjs"
    },
    "./ngmodule": {
      "types": "./dist/types/journium-angular-ngmodule.d.ts",
      "default": "./dist/fesm2022/journium-angular-ngmodule.mjs"
    }
  },
  "homepage": "https://github.com/journium/journium-js",
  "bugs": {
    "url": "https://github.com/journium/journium-js/issues"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --passWithNoTests",
    "test:compat": "cd test-compat && ./test-all.sh",
    "test:compat:15": "cd test-compat && ./test-angular-15.sh",
    "test:compat:16": "cd test-compat && ./test-angular-16.sh",
    "test:compat:17": "cd test-compat && ./test-angular-17.sh",
    "test:compat:18": "cd test-compat && ./test-angular-18.sh",
    "test:compat:19": "cd test-compat && ./test-angular-19.sh",
    "test:compat:21": "cd test-compat && ./test-angular-21.sh",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@journium/js": "workspace:*",
    "@journium/core": "workspace:*"
  },
  "peerDependencies": {
    "@angular/core": ">=19.0.0",
    "@angular/router": ">=19.0.0",
    "rxjs": ">=6.5.0"
  },
  "peerDependenciesMeta": {
    "@angular/router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@types/node": "^20.0.0",
    "ng-packagr": "^21.2.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.0.0",
    "typescript": "^5.9.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/journium/journium-js.git",
    "directory": "packages/journium-angular"
  },
  "keywords": [
    "analytics",
    "tracking",
    "journium",
    "angular",
    "service",
    "provider",
    "dependency-injection",
    "web-analytics",
    "typescript"
  ],
  "author": "Journium Team",
  "publishConfig": {
    "access": "public"
  }
}
