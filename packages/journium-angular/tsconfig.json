{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "emitDecoratorMetadata": false,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2018", "DOM"],
    "paths": {
      "@journium/angular": ["./src/index.ts"]
    }
  },
  "include": ["src/**/*", "ngmodule/**/*"],
  "exclude": ["dist", "node_modules", "**/*.test.ts"]
}
