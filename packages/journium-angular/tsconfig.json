{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2018", "DOM"]
